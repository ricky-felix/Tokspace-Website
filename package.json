{
	"name": "website",
	"version": "2.0.0",
	"description": "This template provides a minimal setup to get React working in Vite with HMR and some ESLint rules.",
	"homepage": "https://github.com/rickyfelix19/Tokspace-Website#readme",
	"bugs": {
		"url": "https://github.com/rickyfelix19/Tokspace-Website/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rickyfelix19/Tokspace-Website.git"
	},
	"license": "ISC",
	"author": "Ricky Felix",
	"type": "commonjs",
	"main": "index.js",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"dev-database": "concurrently \"cd ./database && npm run server\" \"cd ./database npm run client\"",
		"dev-client": "concurrently \"cd ./client && npm start\"",
		"dev": "concurrently \"npm start dev-client\" \"npm start dev-database\"",
		"server": "nodemon database/Server.js",
		"start-build": "cd client && npm run build",
		"start": "cd client && npm start",
		"install-database": "cd database && npm i",
		"install-client": "cd client && npm i",
		"start-server": "concurrently \"cd client && npm run build\" \"nodemon database/Server.js\""
	},
	"dependencies": {
		"concurrently": "^9.2.0",
		"nodemon": "^3.1.10"
	}
}
